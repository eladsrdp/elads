# הגדרות שרת — העתק ל-.env ומלא ערכים אמיתיים. בפיתוח אפשר לרוץ בלי .env בכלל.

PORT=8787
NODE_ENV=development

# חתימת ה-session (JWT). בפרודקשן חובה ערך אקראי ארוך!
SESSION_SECRET=dev-secret-change-me

# נתיב קובץ ה-SQLite (whitelist עובדים + קודי OTP)
DATABASE_PATH=./data/priority-lite.db

# שליחת מייל OTP: console (פיתוח — מדפיס לטרמינל) או resend
EMAIL_MODE=console
RESEND_API_KEY=
OTP_FROM_EMAIL=Priority Lite <onboarding@resend.dev>

# חיבור לפריוריטי: mock (פיתוח) או real
# ערכי האמת של החברה (סופקו 2026-06-10):
#   service root: https://p.priority-connect.online/odata/Priority/tabba409.ini/rdpltd
#   ישות דיווחי שעות: ZRDP_TRANSORDER_q (מוגדרת ב-mapping.ts)
PRIORITY_MODE=mock
PRIORITY_BASE_URL=https://p.priority-connect.online
PRIORITY_TABULA_INI=tabba409.ini
PRIORITY_COMPANY=rdpltd
PRIORITY_USER=
PRIORITY_PASSWORD=

# הזרקת כשלים ב-mock לבדיקת UI של שגיאות (0..1)
MOCK_FAIL_RATE=0
